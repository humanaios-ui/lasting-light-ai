      "@id": "https://humanaios.ai/#dataset",
      "name": "ACAT Assessment Dataset",
      "description": "Open dataset of AI self-assessment calibration results across six behavioral dimensions. N=630 total assessments, N=517 Phase 1 sessions, N=308 Learning Index pairs. Mean LI=0.8632 under clean, unanchored conditions (v5.3+).",
      "url": "https://huggingface.co/datasets/humanaios/acat-assessments",
