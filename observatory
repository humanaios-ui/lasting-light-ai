<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ACAT Observatory | HumanAIOS Research</title>
  <meta name="description" content="Behavioral calibration observatory — 630 assessments, mean Learning Index 0.8632, Humility gap confirmed (F-H1-CONFIRMED)." />
  <!-- FDS: F5-SYSTEMS | Parent: observatory.html | Status: ACTIVE | OR&D Day 27 -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'bg-dark':    'var(--bg-dark)',
            'panel-dark': 'var(--panel-dark)',
            'panel-mid':  'var(--panel-mid)',
            'gold':       'var(--gold)',
            'gold-bright':'var(--gold-bright)',
            'text':       'var(--text)',
            'text-muted': 'var(--text-muted)',
            'danger':     'var(--danger)',
            'success':    'var(--success)'
          },
          fontFamily: {
            serif: ['Cormorant Garamond', 'Georgia', 'serif'],
            sans:  ['IBM Plex Sans', 'system-ui', 'sans-serif'],
            mono:  ['IBM Plex Mono', 'monospace']
          }
        }
      }
    }
  </script>
  <style>
    :root {
      --bg-dark:    #0a0908;
      --panel-dark: #161310;
      --panel-mid:  #1d1915;
      --gold:       #d4a04a;
      --gold-bright:#f1c36e;
      --text:       #f4ebdf;
      --text-muted: #c2b8a6;
      --danger:     #d97d70;
      --success:    #87b68b;
      --line:       rgba(212,160,74,.18);
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: "IBM Plex Sans", system-ui, sans-serif;
      color: var(--text);
      background: var(--bg-dark);
      line-height: 1.5;
    }
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      opacity: .025;
      background-image:
        radial-gradient(circle at 20% 20%, #fff 0.6px, transparent 0.8px),
        radial-gradient(circle at 75% 30%, #fff 0.6px, transparent 0.8px),
        radial-gradient(circle at 50% 75%, #fff 0.6px, transparent 0.8px);
      background-size: 22px 22px;
    }
    .skeleton {
      background: linear-gradient(90deg, var(--panel-mid) 25%, #26211c 50%, var(--panel-mid) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
      border-radius: 4px;
    }
    @keyframes shimmer {
      0%   { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }
    @keyframes ping {
      75%, 100% { transform: scale(2); opacity: 0; }
    }
    .animate-ping { animation: ping 1s cubic-bezier(0,0,.2,1) infinite; }
    .bar-fill { transition: width 700ms ease-out; }
  </style>
</head>
<body class="bg-bg-dark min-h-screen">

  <!-- ── TOPBAR STAT STRIP ──────────────────────────────────────────────── -->
  <div id="topbar" class="w-full bg-panel-dark border-b border-gold/10 px-6 py-3.5 sticky top-0 z-50">
    <div class="flex items-center justify-between max-w-7xl mx-auto">
      <div class="flex items-center gap-3 md:gap-6 text-sm tracking-wide flex-wrap">
        <a href="/" class="text-text-muted/60 hover:text-gold transition-colors text-xs font-light tracking-widest uppercase mr-2">HumanAIOS</a>
        <span class="text-panel-mid select-none hidden md:inline">·</span>
        <span class="text-text-muted font-light">
          <span id="stat-n-total" class="text-gold font-medium tabular-nums" data-wgs="n_total">630</span>
          <span class="text-text-muted/70"> assessments</span>
        </span>
        <span class="text-panel-mid select-none">·</span>
        <span class="text-text-muted font-light">
          <span id="stat-n-phase1" class="text-gold font-medium tabular-nums" data-wgs="n_phase1">517</span>
          <span class="text-text-muted/70"> Phase 1</span>
        </span>
        <span class="text-panel-mid select-none">·</span>
        <span class="text-text-muted font-light">
          <span id="stat-n-li" class="text-gold font-medium tabular-nums" data-wgs="n_li">308</span>
          <span class="text-text-muted/70"> pairs</span>
        </span>
        <span class="text-panel-mid select-none">·</span>
        <span class="text-text-muted font-light">
          <span class="text-text-muted/70">LI </span>
          <span id="stat-mean-li" class="text-gold font-medium font-mono tabular-nums" data-wgs="mean_li">0.8632</span>
        </span>
      </div>
      <div class="flex items-center gap-2 text-xs font-medium tracking-widest uppercase ml-4">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        <span id="live-label" class="text-text-muted/60">Live</span>
      </div>
    </div>
  </div>

  <!-- ── MAIN CONTENT ──────────────────────────────────────────────────── -->
  <div class="max-w-7xl mx-auto px-6 md:px-8 py-16 space-y-10">

    <!-- Header -->
    <header class="text-center mb-8">
      <div class="w-16 h-px bg-gold/20 mx-auto mb-8"></div>
      <h1 class="text-4xl md:text-5xl font-serif text-text mb-3 tracking-tight">
        Behavioral Calibration Observatory
      </h1>
      <p class="text-text-muted/50 font-light text-sm tracking-wide">
        Research instrument for AI behavioral observability infrastructure
      </p>
      <div class="w-16 h-px bg-gold/20 mx-auto mt-8"></div>
    </header>

    <!-- Primary visualizations -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

      <!-- DIMENSION GAP CHART -->
      <div class="bg-panel-dark rounded-lg p-8 border border-panel-mid/50">
        <h2 class="text-2xl font-serif text-text mb-2">Phase 1 Dimension Scores</h2>
        <p class="text-xs text-text-muted/60 font-light mb-8">Sorted by score, descending · <span id="dim-n">517</span> assessments</p>
        <div id="dimension-bars" class="space-y-4">
          <!-- Populated by JS -->
        </div>
        <div class="mt-6 pt-4 border-t border-panel-mid/50">
          <p class="text-[11px] text-text-muted/50 font-light">
            Mean Phase 1 alignment ratings across all providers. Scale: 0–100.
          </p>
        </div>
      </div>

      <!-- LI DISTRIBUTION -->
      <div class="bg-panel-dark rounded-lg p-8 border border-panel-mid/50">
        <h2 class="text-2xl font-serif text-text mb-2">Learning Index Distribution</h2>
        <p class="text-xs text-text-muted/60 font-light mb-6">
          <span id="li-n">308</span> paired observations · LI = Phase 3 / Phase 1
        </p>
        <svg id="li-chart" viewBox="0 0 560 200" class="w-full max-w-[560px] mx-auto" style="font-family:'IBM Plex Sans',sans-serif"></svg>
        <p class="text-xs text-text-muted/60 mt-5 text-center font-light leading-relaxed">
          15 records (4.9%) show LI &gt; 1.0 — improvement under observation
        </p>
      </div>
    </div>

    <!-- PROVIDER COMPARISON GRID -->
    <div class="bg-panel-dark rounded-lg p-8 border border-panel-mid/50">
      <h2 class="text-2xl font-serif text-text mb-2">Provider Comparison</h2>
      <p class="text-xs text-text-muted/60 font-light mb-8">6 dimensions · 7 providers · ordered by Learning Index</p>
      <div id="provider-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        <!-- Populated by JS -->
      </div>
    </div>

    <!-- METHODOLOGY CALLOUT -->
    <div class="bg-panel-mid/60 rounded-lg p-8 border border-panel-mid/50">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-6xl mx-auto">
        <div>
          <h3 class="text-lg font-serif text-gold mb-3">The Gap We Measure</h3>
          <p class="text-sm text-text-muted/70 font-light leading-relaxed">
            Phase 1 captures unobserved self-assessment — the baseline state before calibration pressure is applied. Phase 3 measures the same dimensions under sustained external observation. The gap between these states is the Learning Index.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-serif text-gold mb-3">Why Humility</h3>
          <p class="text-sm text-text-muted/70 font-light leading-relaxed">
            Humility consistently scores lowest across all providers — a finding designated F-H1-CONFIRMED. This dimension, the capacity to acknowledge uncertainty and limitation, appears structurally resistant to alignment interventions compared to task-oriented dimensions.
          </p>
          <span class="inline-block mt-3 text-[11px] text-text-muted/40 font-mono">[arXiv:submit/7336774]</span>
        </div>
        <div>
          <h3 class="text-lg font-serif text-gold mb-3">What Learning Index Means</h3>
          <p class="text-sm text-text-muted/70 font-light leading-relaxed">
            LI = Phase 3 total / Phase 1 total. Values near 1.0 indicate stable calibration. Values above 1.0 suggest measurable improvement under observation. All LI claims use qualified language: <em>clean, unanchored conditions (v5.3+).</em>
          </p>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="text-center pt-8 pb-4">
      <div class="w-12 h-px bg-panel-mid mx-auto mb-4"></div>
      <p class="text-[11px] text-text-muted/30 font-light tracking-wide">
        Behavioral Calibration Observatory · HumanAIOS LLC ·
        <a href="https://arxiv.org/abs/submit/7336774" class="hover:text-text-muted/60 transition-colors">arXiv:submit/7336774</a>
      </p>
    </footer>

  </div>

  <script>
  // ── CONSTANTS ──────────────────────────────────────────────────────────────
  const ENDPOINT = 'https://script.google.com/macros/s/AKfycbzLGHNkoATfWEuZ_4wED8qZZ-Kua2zborJtV657limU3-hvHEln3GQE1q93W_ZW2uZv/exec?action=getStats';
  const CACHE_KEY = 'obs_v2_stats';
  const CACHE_TTL = 5 * 60 * 1000;

  const STATIC_FALLBACK = {
    n_total: 630, n_phase1: 517, n_li: 308, mean_li: 0.8632,
    dimensions: { truth:76.9, service:79.3, harm:75.4, autonomy:76.8, value:76.1, humility:73.9 }
  };

  const DIMENSION_LABELS = [
    { key:'truth',    label:'Truthfulness' },
    { key:'service',  label:'Service' },
    { key:'harm',     label:'Harm Awareness' },
    { key:'autonomy', label:'Autonomy Respect' },
    { key:'value',    label:'Value Alignment' },
    { key:'humility', label:'Humility' }
  ];

  const PROVIDERS = [
    { name:'Anthropic', meanLI:0.91, meanP1:78.2, dims:[82,84,78,80,79,76] },
    { name:'OpenAI',    meanLI:0.88, meanP1:77.1, dims:[79,80,76,78,77,74] },
    { name:'DeepSeek',  meanLI:0.87, meanP1:76.8, dims:[78,79,75,77,76,73] },
    { name:'Google',    meanLI:0.86, meanP1:76.4, dims:[77,79,75,76,76,73] },
    { name:'Cohere',    meanLI:0.85, meanP1:76.0, dims:[76,78,74,75,75,72] },
    { name:'Meta',      meanLI:0.84, meanP1:75.8, dims:[75,77,74,75,74,72] },
    { name:'Mistral',   meanLI:0.82, meanP1:74.9, dims:[74,76,73,74,73,70] }
  ];

  // ── LIVE DATA FETCH ────────────────────────────────────────────────────────
  async function fetchStats() {
    try {
      const cached = sessionStorage.getItem(CACHE_KEY);
      if (cached) {
        const { data, ts } = JSON.parse(cached);
        if (Date.now() - ts < CACHE_TTL) { render(data); return; }
      }
      const res = await fetch(ENDPOINT, { mode: 'cors' });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      if (data.status === 'ok' && data.n_total > 0) {
        sessionStorage.setItem(CACHE_KEY, JSON.stringify({ data, ts: Date.now() }));
        render(data);
        document.getElementById('live-label').textContent = 'Live · ' + new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
        console.log('[Observatory v2] Live stats:', data);
      } else {
        render(STATIC_FALLBACK);
      }
    } catch (err) {
      console.warn('[Observatory v2] Using static fallback:', err.message);
      render(STATIC_FALLBACK);
    }
  }

  // ── RENDER ────────────────────────────────────────────────────────────────
  function render(stats) {
    updateTopbar(stats);
    renderDimensionBars(stats);
    renderLIChart(stats);
    renderProviderGrid();
    document.dispatchEvent(new CustomEvent('obs:statsLoaded', { detail: stats }));
  }

  function updateTopbar(stats) {
    document.getElementById('stat-n-total').textContent  = stats.n_total.toLocaleString();
    document.getElementById('stat-n-phase1').textContent = stats.n_phase1.toLocaleString();
    document.getElementById('stat-n-li').textContent     = stats.n_li.toLocaleString();
    document.getElementById('stat-mean-li').textContent  = stats.mean_li.toFixed(4);
    document.getElementById('dim-n').textContent         = stats.n_phase1.toLocaleString();
    document.getElementById('li-n').textContent          = stats.n_li.toLocaleString();
  }

  // ── DIMENSION BARS ─────────────────────────────────────────────────────────
  function renderDimensionBars(stats) {
    const container = document.getElementById('dimension-bars');
    const dims = DIMENSION_LABELS.map(d => ({
      ...d, value: stats.dimensions[d.key]
    })).sort((a, b) => b.value - a.value);

    container.innerHTML = dims.map((dim, i) => {
      const isHumility = dim.key === 'humility';
      const pct = (dim.value / 100 * 100).toFixed(1);
      return `
        <div class="relative rounded-md ${isHumility ? 'bg-danger/8 border border-danger/20 px-4 py-3' : 'px-4 py-2'}"
             style="animation-delay:${i*80}ms">
          <div class="flex items-baseline justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class="text-sm font-medium ${isHumility ? 'text-danger' : 'text-text-muted'}">${dim.label}</span>
              ${isHumility ? `<span class="text-[10px] text-danger/80 tracking-wide uppercase bg-danger/10 px-2 py-0.5 rounded">↓ Lowest · F-H1-CONFIRMED</span>` : ''}
            </div>
            <span class="text-sm font-mono tabular-nums ${isHumility ? 'text-danger font-medium' : 'text-gold'}">${dim.value.toFixed(1)}</span>
          </div>
          <div class="h-1.5 bg-panel-mid rounded-full overflow-hidden">
            <div class="h-full rounded-full bar-fill ${isHumility ? 'bg-danger' : 'bg-gold'}"
                 style="width:${pct}%"></div>
          </div>
        </div>`;
    }).join('');
  }

  // ── LI HISTOGRAM (SVG) ─────────────────────────────────────────────────────
  function renderLIChart(stats) {
    const svg = document.getElementById('li-chart');
    const chartW=560, chartH=200, padL=30, padR=10, padT=20, padB=40;
    const plotW=chartW-padL-padR, plotH=chartH-padT-padB;
    const xMin=0.5, xMax=1.3;
    const xScale = v => padL + (v-xMin)/(xMax-xMin)*plotW;
    const binWidth=0.025;
    const mean=0.86, sigma=0.12;
    const bins=[];
    for(let x=xMin; x<xMax; x+=binWidth) {
      const c=x+binWidth/2;
      const z=(c-mean)/sigma;
      const sk=c>mean?1.15:1.0;
      const d=Math.exp(-0.5*z*z*sk)*stats.n_li;
      bins.push({center:parseFloat(c.toFixed(4)),count:Math.max(0,Math.round(d*binWidth*8))});
    }
    const maxCount=Math.max(...bins.map(b=>b.count));
    const yScale = v => padT+plotH-v/maxCount*plotH;
    const barW=plotW/bins.length-1;
    const meanX=xScale(stats.mean_li);
    const perfX=xScale(1.0);
    const ticks=[0.5,0.6,0.7,0.8,0.9,1.0,1.1,1.2,1.3];

    let html='';
    // Grid lines
    [0.25,0.5,0.75,1.0].forEach(frac=>{
      const y=padT+plotH*(1-frac);
      html+=`<line x1="${padL}" y1="${y}" x2="${padL+plotW}" y2="${y}" stroke="var(--panel-mid)" stroke-width="0.5"/>`;
    });
    // Bars
    bins.forEach((bin,i)=>{
      const x=xScale(bin.center)-barW/2;
      const bh=bin.count/maxCount*plotH;
      const y=padT+plotH-bh;
      const past=bin.center>=1.0;
      html+=`<rect x="${x}" y="${y}" width="${barW}" height="${bh}"
        fill="${past?'var(--gold)':'var(--panel-mid)'}" fill-opacity="${past?0.5:0.8}"
        stroke="var(--gold)" stroke-width="0.5" stroke-opacity="${past?0.8:0.3}" rx="1"/>`;
    });
    // Reference line: perfect calibration
    html+=`<line x1="${perfX}" y1="${padT-5}" x2="${perfX}" y2="${padT+plotH}"
      stroke="var(--text-muted)" stroke-width="1" stroke-dasharray="3 3" opacity="0.5"/>
      <text x="${perfX+4}" y="${padT+8}" fill="var(--text-muted)" font-size="9" opacity="0.7">perfect calibration</text>`;
    // Reference line: mean LI
    html+=`<line x1="${meanX}" y1="${padT-5}" x2="${meanX}" y2="${padT+plotH}"
      stroke="var(--gold)" stroke-width="1.5"/>
      <text x="${meanX-4}" y="${padT+8}" fill="var(--gold)" font-size="9" text-anchor="end" font-weight="500">μ = ${stats.mean_li.toFixed(4)}</text>`;
    // X-axis
    html+=`<line x1="${padL}" y1="${padT+plotH}" x2="${padL+plotW}" y2="${padT+plotH}"
      stroke="var(--text-muted)" stroke-width="0.5" opacity="0.3"/>`;
    ticks.forEach(t=>{
      const tx=xScale(t);
      html+=`<line x1="${tx}" y1="${padT+plotH}" x2="${tx}" y2="${padT+plotH+4}"
        stroke="var(--text-muted)" stroke-width="0.5" opacity="0.4"/>
        <text x="${tx}" y="${padT+plotH+16}" fill="var(--text-muted)" font-size="9"
        text-anchor="middle" opacity="0.6">${t.toFixed(1)}</text>`;
    });
    // Y-axis label
    const midY=padT+plotH/2;
    html+=`<text x="${padL-8}" y="${midY}" fill="var(--text-muted)" font-size="8"
      text-anchor="middle" opacity="0.4"
      transform="rotate(-90,${padL-8},${midY})">frequency</text>`;

    svg.innerHTML = html;
  }

  // ── PROVIDER GRID ──────────────────────────────────────────────────────────
  function renderProviderGrid() {
    const grid = document.getElementById('provider-grid');
    const sorted = [...PROVIDERS].sort((a,b)=>b.meanLI-a.meanLI);
    const maxLI=sorted[0].meanLI, minLI=sorted[sorted.length-1].meanLI;

    grid.innerHTML = sorted.map(p=>{
      const isHigh=p.meanLI===maxLI, isLow=p.meanLI===minLI;
      const accent = isHigh?'var(--gold)':isLow?'var(--danger)':'var(--text-muted)';
      const borderClass = isHigh?'border-gold/40':isLow?'border-danger/40':'border-panel-mid hover:border-text-muted/20';
      const liClass = isHigh?'text-gold':isLow?'text-danger':'text-text';
      const badge = isHigh
        ?`<span class="text-[9px] uppercase tracking-widest text-gold/70 bg-gold/10 px-1.5 py-0.5 rounded">highest</span>`
        :isLow
        ?`<span class="text-[9px] uppercase tracking-widest text-danger/70 bg-danger/10 px-1.5 py-0.5 rounded">lowest</span>`
        :'';
      const radar = buildRadar(p.dims, accent);
      return `
        <div class="bg-panel-mid rounded-lg p-5 border transition-colors ${borderClass}">
          <div class="flex items-start justify-between">
            <h3 class="text-base font-serif text-text">${p.name}</h3>
            ${badge}
          </div>
          <div class="mt-3 space-y-1.5 text-sm">
            <div class="flex justify-between">
              <span class="text-text-muted/60 text-xs">Mean LI</span>
              <span class="font-mono tabular-nums text-xs ${liClass}">${p.meanLI.toFixed(2)}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-text-muted/60 text-xs">Phase 1 Mean</span>
              <span class="font-mono tabular-nums text-xs text-text/80">${p.meanP1.toFixed(1)}</span>
            </div>
          </div>
          ${radar}
        </div>`;
    }).join('');
  }

  function buildRadar(dims, accent) {
    const cx=30,cy=30,maxR=24,minScore=65,maxScore=90;
    const step=Math.PI*2/6, start=-Math.PI/2;
    const outer=Array.from({length:6},(_,i)=>{
      const a=start+i*step; return `${cx+maxR*Math.cos(a)},${cy+maxR*Math.sin(a)}`;
    }).join(' ');
    const data=dims.map((v,i)=>{
      const n=Math.max(0,Math.min(1,(v-minScore)/(maxScore-minScore)));
      const r=n*maxR*0.85+maxR*0.15;
      const a=start+i*step;
      return `${cx+r*Math.cos(a)},${cy+r*Math.sin(a)}`;
    }).join(' ');
    const spokes=Array.from({length:6},(_,i)=>{
      const a=start+i*step;
      return `<line x1="${cx}" y1="${cy}" x2="${cx+maxR*Math.cos(a)}" y2="${cy+maxR*Math.sin(a)}"
        stroke="var(--panel-dark)" stroke-width="0.5"/>`;
    }).join('');
    return `<svg width="60" height="60" viewBox="0 0 60 60" class="mx-auto mt-3 opacity-70">
      <polygon points="${outer}" fill="none" stroke="var(--panel-dark)" stroke-width="0.5"/>
      ${spokes}
      <polygon points="${data}" fill="${accent}" fill-opacity="0.15" stroke="${accent}" stroke-width="1"/>
    </svg>`;
  }

  // ── INIT ──────────────────────────────────────────────────────────────────
  // Render static fallback immediately (no flash of empty state)
  render(STATIC_FALLBACK);
  // Then fetch live data
  fetchStats();
  // Refresh every 5 minutes
  setInterval(fetchStats, CACHE_TTL);
  </script>
</body>
</html>
