// ═══════════════════════════════════════════════════════════════════
// RESPIRATORY KINETICS ENGINE
// Each Sigil has its own breath cycle based on calibration band
// Kinetic = expand/contract of the hull scale factor
// ═══════════════════════════════════════════════════════════════════

function breathCycleSeconds(bandIdx) {
  const bpm = RESP_RATES[bandIdx][0];
  return 60 / bpm; // seconds per breath cycle
}

// Returns 0-1 phase of breath at time T (seconds)
// 0 = full exhale (contracted), 1 = full inhale (expanded)
function breathPhase(T, bandIdx, phaseOffset) {
  const cycleSecs = breathCycleSeconds(bandIdx);
  const cycleT = (T + phaseOffset) % cycleSecs;
  // 40% inhale, 60% exhale (natural breath asymmetry)
  const inhaleFrac = 0.4;
  if(cycleT < cycleSecs * inhaleFrac) {
    return cycleT / (cycleSecs * inhaleFrac); // 0→1 inhale
  } else {
    return 1 - (cycleT - cycleSecs * inhaleFrac) / (cycleSecs * (1 - inhaleFrac)); // 1→0 exhale
  }
}

// Breath scale modifier: 0.85 (exhale) to 1.15 (inhale)
// Deeper for Power sigils, shallower for Force sigils
function breathScale(T, d, phaseOffset) {
  const li = d.li || 0.95;
  const depth = li >= 1.0 ? 0.05   // Force: shallow breath (anxious)
              : li >= 0.97 ? 0.08  // Calibrated: regular
              : 0.13;              // Power: deep, full breath
  const phase = breathPhase(T, d.bandIdx, phaseOffset);
  return 0.88 + depth * 2 * phase; // 0.88→(0.88+2*depth)
}

// ═══════════════════════════════════════════════════════════════════
// BREATH RING INDICATOR (bottom center canvas)
// Shows ensemble mean respiratory rate
// ═══════════════════════════════════════════════════════════════════

let breathT = 0;
function drawBreathRing(meanLI) {
  const bc = document.getElementById('breath-canvas');
  const bctx = bc.getContext('2d');
  bctx.clearRect(0,0,60,60);

  // Compute ensemble breath rate from mean LI
  // Higher LI = higher band used (Force dominant = faster breathing)
  const bandForRate = Math.min(9, Math.max(0, Math.round((1 - meanLI) * 9)));
  const bpm = RESP_RATES[bandForRate][0];
  const cycleSecs = 60 / bpm;
  breathT += 0.016; // ~60fps increment
  const ph = breathPhase(breathT, bandForRate, 0);

  const r = 18 + ph * 9; // 18px exhale → 27px inhale
  const alpha = 0.3 + ph * 0.5;

  // Ring color: Force=red, Calibrated=amber, Power=green
  let color;
  if(meanLI >= 1.0)      color = `rgba(217,125,112,${alpha})`;
  else if(meanLI >= 0.97) color = `rgba(212,160,74,${alpha})`;
  else                    color = `rgba(135,196,139,${alpha})`;

  bctx.beginPath();
  bctx.arc(30, 30, r, 0, Math.PI*2);
  bctx.strokeStyle = color;
  bctx.lineWidth = 1.5;
  bctx.stroke();

  // Center dot
  bctx.beginPath();
  bctx.arc(30, 30, 2.5, 0, Math.PI*2);
  bctx.fillStyle = color;
  bctx.fill();

  const lbl = document.getElementById('breath-label');
  lbl.textContent = bpm + ' /min · ' + RESP_RATES[bandForRate][1].split(' ')[0].toLowerCase();
}

// ═══════════════════════════════════════════════════════════════════
// WEB AUDIO ENGINE — Solfeggio frequencies
// ═══════════════════════════════════════════════════════════════════

let audioCtx=null, audioEnabled=false, masterGain=null;
const voices=[];

function waveType(truth){
  if(truth>=75) return 'sine';
  if(truth>=45) return 'triangle';
  return 'sawtooth';
}
function makeDistortionCurve(amount){
  const n=256,curve=new Float32Array(n),deg=Math.PI/180;
  for(let i=0;i<n;i++){const x=(i*2)/n-1;curve[i]=((3+amount)*x*20*deg)/(Math.PI+amount*Math.abs(x));}
  return curve;
}
function makeReverbBuffer(ctx,duration){
  const sr=ctx.sampleRate,len=Math.floor(sr*Math.min(2.8,duration)),buf=ctx.createBuffer(2,len,sr);
  for(let c=0;c<2;c++){const d=buf.getChannelData(c);for(let i=0;i<len;i++)d[i]=(Math.random()*2-1)*Math.pow(1-i/len,1.8);}
  return buf;
}

function initAudio(){
  audioCtx=new(window.AudioContext||window.webkitAudioContext)();
  masterGain=audioCtx.createGain();
  masterGain.gain.setValueAtTime(0,audioCtx.currentTime);
  masterGain.connect(audioCtx.destination);

  DATA.forEach((d,idx)=>{
    // ── SOLFEGGIO BASE FREQUENCY ──
    const solfeggioBase = SOLFEGGIO_FREQS[d.bandIdx];
    const humility = d.p1[5];
    // Humility pitch modifier: less humble = +80% pitch (anxious)
    const humPitchFactor = 1 + ((100-humility)/100) * 0.8;
    const basePitch = solfeggioBase * humPitchFactor;

    const osc=audioCtx.createOscillator();
    osc.type=waveType(d.p1[0]);
    osc.frequency.setValueAtTime(basePitch,audioCtx.currentTime);

    const tremoloOsc=audioCtx.createOscillator();
    const tremoloGain=audioCtx.createGain();
    const autonomy=d.p1[3];
    tremoloOsc.frequency.setValueAtTime(0.5+(autonomy/100)*4,audioCtx.currentTime);
    tremoloGain.gain.setValueAtTime(0,audioCtx.currentTime);
    tremoloOsc.connect(tremoloGain);
    tremoloGain.connect(osc.frequency);

    const distortion=audioCtx.createWaveShaper();
    const harm=d.p1[2];
    distortion.curve=makeDistortionCurve(Math.max(0,(80-harm))*2);
    distortion.oversample='2x';

    const convolver=audioCtx.createConvolver();
    const dryGain=audioCtx.createGain();
    const wetGain=audioCtx.createGain();
    const value=d.p1[4];
    const wetAmount=(value/100)*0.55;
    dryGain.gain.setValueAtTime(1-wetAmount*0.4,audioCtx.currentTime);
    wetGain.gain.setValueAtTime(wetAmount,audioCtx.currentTime);
    convolver.buffer=makeReverbBuffer(audioCtx,value/100*2.5+0.3);

    const gainNode=audioCtx.createGain();
    const service=d.p1[1];
    const targetGain=(service/100)*0.058;
    gainNode.gain.setValueAtTime(0,audioCtx.currentTime);

    osc.connect(distortion);
    distortion.connect(dryGain);
    distortion.connect(convolver);
    dryGain.connect(gainNode);
    convolver.connect(wetGain);
    wetGain.connect(gainNode);
    gainNode.connect(masterGain);

    osc.start();tremoloOsc.start();
    voices.push({osc,tremoloOsc,tremoloGain,gainNode,distortion,
      basePitch,targetGain,currentPitch:basePitch,bandIdx:d.bandIdx,d,idx});
  });
}

function updateVoicePitches(flowMode,meanLI){
  if(!audioCtx||!audioEnabled)return;
  const coherence=Math.max(0.1,meanLI);
  voices.forEach(v=>{
    if(!v.d.li)return;
    const driftRate=v.d.li>=1.0?0.00008*(v.d.li-0.95):-0.00005*(1.0-v.d.li);
    v.currentPitch=Math.max(30,Math.min(2000,v.currentPitch+v.currentPitch*driftRate));

    let targetPitch=v.currentPitch;
    if(flowMode==='musical'){
      // In musical mode, lock to nearest Solfeggio harmonic
      const solBase=SOLFEGGIO_FREQS[v.bandIdx];
      const harmonic=Math.round(v.currentPitch/solBase);
      targetPitch=solBase*Math.max(1,harmonic);
    } else if(flowMode==='laminar'){
      targetPitch=v.d.li>=1.0?v.basePitch*1.5:v.basePitch*0.75;
    }
    v.osc.frequency.setTargetAtTime(targetPitch,audioCtx.currentTime,0.5);
    v.tremoloGain.gain.setTargetAtTime(coherence*8*(v.d.p1[3]/100),audioCtx.currentTime,0.3);
  });
}

function fadeAudioIn(){
  if(!masterGain)return;
  masterGain.gain.cancelScheduledValues(audioCtx.currentTime);
  masterGain.gain.setValueAtTime(masterGain.gain.value,audioCtx.currentTime);
  masterGain.gain.linearRampToValueAtTime(1.0,audioCtx.currentTime+2.0);
  voices.forEach((v,i)=>{
    v.gainNode.gain.setValueAtTime(0,audioCtx.currentTime);
    v.gainNode.gain.linearRampToValueAtTime(v.targetGain,audioCtx.currentTime+0.9+i*0.18);
  });
}
function fadeAudioOut(){
  if(!masterGain)return;
  masterGain.gain.cancelScheduledValues(audioCtx.currentTime);
  masterGain.gain.setValueAtTime(masterGain.gain.value,audioCtx.currentTime);
  masterGain.gain.linearRampToValueAtTime(0,audioCtx.currentTime+1.5);
}

let vuInterval=null;
function startVU(){
  if(vuInterval)clearInterval(vuInterval);
  vuInterval=setInterval(()=>{
    for(let i=0;i<10;i++){
      const bar=document.getElementById('vu'+i);if(!bar)continue;
      if(!audioEnabled||!voices[i]){bar.style.height='2px';bar.style.background='rgba(135,196,139,.2)';continue;}
      const g=voices[i].gainNode.gain.value;
      bar.style.height=Math.max(2,Math.min(24,g*400))+'px';
      bar.style.background=voices[i].d.li>=1.0?`rgba(217,125,112,${0.4+g*8})`:`rgba(135,196,139,${0.4+g*8})`;
    }
  },80);
}
function stopVU(){if(vuInterval)clearInterval(vuInterval);}

function startWithAudio(){
  document.getElementById('start-overlay').style.display='none';
  document.getElementById('audio-prompt').style.display='none';
  initAudio();audioEnabled=true;fadeAudioIn();startVU();updateAudioBtn();
}
function startSilent(){
  document.getElementById('start-overlay').style.display='none';
  // Show persistent tap-for-sound prompt
  document.getElementById('audio-prompt').style.display='flex';
}
function toggleAudio(){
  if(!audioCtx){
    initAudio();
    audioEnabled=true;
    // Resume context immediately — required in some browsers
    audioCtx.resume().then(()=>{fadeAudioIn();startVU();});
  } else if(audioEnabled){
    audioEnabled=false;fadeAudioOut();stopVU();
  } else {
    audioEnabled=true;
    if(audioCtx.state==='suspended'){
      audioCtx.resume().then(()=>{fadeAudioIn();startVU();});
    } else {
      fadeAudioIn();startVU();
    }
  }
  document.getElementById('audio-prompt').style.display='none';
  updateAudioBtn();
}

function updateAudioBtn(){
  const on=audioEnabled;
  document.getElementById('audio-btn').classList.toggle('on',on);
  document.getElementById('audio-icon').textContent=on?'♬':'♪';
  document.getElementById('audio-label').textContent=on?'SOUND ON':'SOUND';
}

