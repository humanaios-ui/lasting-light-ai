    const d = await patch('/rentals/'+id, { action:'release' });
    document.getElementById('mr-release-result').innerHTML = d.success
      ? '<div class="msg msg-success">Payment released.</div>'
      : `<div class="msg msg-error">${escHtml(d.error||'Failed')}</div>`;
  } catch(e) { err('mr-release-result', e.message); }
}

