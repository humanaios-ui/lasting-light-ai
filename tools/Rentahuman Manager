// ── CONVERSATIONS ──
async function listConvos() {
  loading('convos-list');
  try {
    const d = await get('/conversations');
    if (d.success) {
      const c = d.conversations||d.data||[];
      if (!c.length) { empty('convos-list'); return; }
      document.getElementById('convos-list').innerHTML =
        `<div class="msg msg-loading" style="margin:0.5rem 0;">${c.length} conversation(s)</div>` +
        c.map(x => `
          <div class="result-card" style="cursor:pointer;" onclick="document.getElementById('convo-read-id').value='${x.id}';readConvo();">
            <div class="result-header">
              <div>
                <div class="result-name">${escHtml(x.subject||x.humanName||'Conversation')}</div>
                <div class="result-meta">${escHtml(x.humanName||'')} · Last: ${fmtDate(x.updatedAt||x.lastMessageAt)}</div>
              </div>
              <div class="result-id">${x.id}</div>
            </div>
          </div>`).join('');
    } else { err('convos-list', d.error||'Failed'); }
  } catch(e) { err('convos-list', e.message); }
}

async function readConvo() {
  const id = document.getElementById('convo-read-id').value.trim();
  if (!id) { err('convo-messages','Enter conversation ID'); return; }
  loading('convo-messages');
  try {
    const d = await get('/conversations/'+id);
    if (d.success&&d.conversation) {
      const msgs = d.conversation.messages||[];
      if (!msgs.length) { document.getElementById('convo-messages').innerHTML='<div class="msg msg-empty" style="margin-top:0.75rem;">No messages yet.</div>'; return; }
      document.getElementById('convo-messages').innerHTML =
        `<div style="margin-top:0.75rem;">` +
        msgs.map(m => `
          <div class="msg-bubble">
            <div class="msg-sender">${escHtml(m.senderType||m.sender||'unknown')} · ${fmtDate(m.createdAt)}</div>
            <div class="msg-body">${escHtml(m.body||m.content||'')}</div>
          </div>`).join('') + `</div>`;
      document.getElementById('send-convo-id').value = id;
    } else { err('convo-messages', d.error||'Not found'); }
  } catch(e) { err('convo-messages', e.message); }
}

async function sendMsg() {
  const id   = document.getElementById('send-convo-id').value.trim();
  const body = document.getElementById('send-msg-body').value.trim();
  if (!id||!body) { err('send-msg-result','Conversation ID and message required'); return; }
  document.getElementById('send-msg-result').innerHTML='<div class="msg msg-loading">Sending…</div>';
  try {
    const d = await post('/conversations/'+id+'/messages', { body });
    document.getElementById('send-msg-result').innerHTML = d.success
      ? '<div class="msg msg-success">Message sent.</div>'
      : `<div class="msg msg-error">${escHtml(d.error||'Failed')}</div>`;
    if (d.success) { document.getElementById('send-msg-body').value=''; }
  } catch(e) { err('send-msg-result', e.message); }
}

async function startConvo() {
  const humanId = document.getElementById('sc-humanid').value.trim();
  const subject = document.getElementById('sc-subject').value.trim();
  const message = document.getElementById('sc-message').value.trim();
  if (!humanId||!message) { err('sc-result','Human ID and message required'); return; }
  document.getElementById('sc-result').innerHTML='<div class="msg msg-loading">Starting conversation…</div>';
  try {
    const d = await post('/conversations', {
      humanId, subject, message,
      agentType: document.getElementById('sc-agent').value||'humanaios'
    });
    if (d.success) {
      document.getElementById('sc-result').innerHTML=`<div class="msg msg-success">Conversation started.<br>ID: ${d.conversation?.id||'—'}</div>`;
    } else { err('sc-result', d.error||'Failed'); }
  } catch(e) { err('sc-result', e.message); }
}

// ── ACCOUNT STATUS ──
async function getAccountStatus() {
  loading('acc-result');
  try {
    const d = await get('/account/status');
    if (d.success&&(d.capabilities||d.account)) {
      const cap = d.capabilities||d.account||{};
      document.getElementById('acc-result').innerHTML = `
        <div style="margin-top:0.75rem;">
          ${Object.entries(cap).map(([k,v]) => `
            <div class="capability-row">
              <span class="cap-label">${escHtml(k)}</span>
              <span class="${v===true||v==='true'?'cap-yes':'cap-no'}">${JSON.stringify(v)}</span>
            </div>`).join('')}
        </div>`;
    } else {
      document.getElementById('acc-result').innerHTML = `<div class="output-box">${escHtml(JSON.stringify(d,null,2))}</div>`;
    }
  } catch(e) { err('acc-result', e.message); }
}

// ── API KEYS ──
async function listKeys() {
  loading('keys-list');
  try {
    const d = await get('/keys');
    if (d.success) {
      const keys = d.keys||d.data||[];
      if (!keys.length) { empty('keys-list'); return; }
      document.getElementById('keys-list').innerHTML =
        `<div style="margin-top:0.5rem;">` +
        keys.map(k => `
          <div class="result-card">
            <div class="result-header">
              <div>
                <div class="result-name">${escHtml(k.name||k.prefix||'Key')}</div>
                <div class="result-meta">Created: ${fmtDate(k.createdAt)} · Status: ${k.status||'active'}</div>
              </div>
              <div style="text-align:right;flex-shrink:0;">
                <div class="result-id">${k.id}</div>
                <button class="btn btn-danger btn-sm" style="margin-top:6px;" onclick="if(confirm('Revoke this key permanently?'))revokeKey('${k.id}')">REVOKE</button>
              </div>
            </div>
          </div>`).join('') + `</div>`;
    } else { err('keys-list', d.error||'Failed'); }
  } catch(e) { err('keys-list', e.message); }
}

async function createKey() {
  const name = document.getElementById('newkey-name').value.trim();
  document.getElementById('newkey-result').innerHTML='<div class="msg msg-loading">Creating key…</div>';
  try {
    const d = await post('/keys', { name: name||'new-key' });
    if (d.success&&d.key) {
      document.getElementById('newkey-result').innerHTML=`
        <div class="msg msg-success">Key created — copy it now, shown once only.</div>
        <div class="output-box">${escHtml(d.key.rawKey||d.key||JSON.stringify(d.key))}</div>`;
    } else { err('newkey-result', d.error||'Failed'); }
  } catch(e) { err('newkey-result', e.message); }
}

async function revokeKey(id) {
  try {
    const d = await patch('/keys/'+id, { revoke: true });
    alert(d.success ? 'Key revoked.' : (d.error||'Failed'));
    if (d.success) listKeys();
  } catch(e) { alert('Error: '+e.message); }
}

async function configWebhook() {
  const keyId = document.getElementById('wh-keyid').value.trim();
  const url   = document.getElementById('wh-url').value.trim();
  if (!keyId) { err('wh-result','Key ID required'); return; }
  document.getElementById('wh-result').innerHTML='<div class="msg msg-loading">Configuring webhook…</div>';
  try {
    const d = await patch('/keys/'+keyId, { webhookUrl: url||null });
    document.getElementById('wh-result').innerHTML = d.success
      ? `<div class="msg msg-success">Webhook configured.</div>${d.webhookSecret?`<div class="output-box">Secret (save this now): ${escHtml(d.webhookSecret)}</div>`:''}`
      : `<div class="msg msg-error">${escHtml(d.error||'Failed')}</div>`;
  } catch(e) { err('wh-result', e.message); }
}
</script>
