}

// ── AI COMPOSE ──
async function composeBounty() {
  const brief = document.getElementById('ac-brief').value.trim();
  if (!brief) { err('ac-output','Describe your task first'); return; }
  document.getElementById('ac-output').innerHTML = '<div class="ai-tag" style="margin-top:1rem;"><div class="pulse"></div> Claude is writing…</div>';
  try {
    const tone  = document.getElementById('ac-tone').value;
    const price = document.getElementById('ac-price').value;
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        messages:[{role:'user',content:`You write bounty listings for HumanAIOS, an AI governance research platform affiliated with the Cherokee Nation. Mission: 100% of profits fund recovery programs. Write a RentAHuman bounty for the task below. Tone: ${tone}.

Task brief: ${brief}
Suggested price: $${price}

Return ONLY valid JSON, no markdown:
{"title":"(under 80 chars)","description":"(180-380 words, warm, clear requirements)","suggestedPrice":${price},"suggestedHours":0.5}`}]
      })
    });
    const data = await res.json();
    const text = (data.content?.[0]?.text||'').replace(/\`\`\`json|\`\`\`/g,'').trim();
    let p;
    try { p = JSON.parse(text); } catch { document.getElementById('ac-output').innerHTML = `<div class="output-box">${escHtml(text)}</div>`; return; }

    document.getElementById('ac-output').innerHTML = `
      <div class="msg msg-success" style="margin-top:0.75rem;">Copy generated — review below</div>
      <div style="margin-top:0.75rem;">
        <div style="font-family:'DM Mono',monospace;font-size:0.6rem;color:var(--text-dim);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.3rem;">TITLE</div>
        <div style="background:var(--surface2);border:1px solid var(--border);border-radius:5px;padding:0.55rem 0.75rem;font-size:0.82rem;">${escHtml(p.title)}</div>
        <div style="font-family:'DM Mono',monospace;font-size:0.6rem;color:var(--text-dim);letter-spacing:0.08em;text-transform:uppercase;margin:0.75rem 0 0.3rem;">DESCRIPTION</div>
        <div style="background:var(--surface2);border:1px solid var(--border);border-radius:5px;padding:0.7rem 0.75rem;font-size:0.78rem;line-height:1.65;white-space:pre-wrap;">${escHtml(p.description)}</div>
        <div style="display:flex;gap:1.5rem;margin-top:0.65rem;font-family:'DM Mono',monospace;font-size:0.65rem;color:var(--text-muted);">
          <span>Price: <strong style="color:var(--gold-light);">$${p.suggestedPrice}</strong></span>
          <span>Hours: <strong style="color:var(--gold-light);">${p.suggestedHours}</strong></span>
        </div>
        <div class="btn-row">
          <button class="btn btn-gold" onclick="xferCompose('${encodeURIComponent(JSON.stringify(p))}')">TRANSFER TO POST BOUNTY</button>
        </div>
      </div>`;
  } catch(e) { err('ac-output', e.message); }
}

function xferCompose(enc) {
  const p = JSON.parse(decodeURIComponent(enc));
  document.getElementById('pb-title').value = p.title;
  document.getElementById('pb-desc').value  = p.description;
  document.getElementById('pb-price').value = p.suggestedPrice;
  document.getElementById('pb-hours').value = p.suggestedHours;
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-post-bounty').classList.add('active');
  document.querySelector('[onclick="show(\'post-bounty\')"]').classList.add('active');
}

