<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HumanAIOS × RentAHuman Console</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700&display=swap');

:root {
  --gold: #C8971A;
  --gold-light: #F0C84A;
  --gold-dim: #7A5A0D;
  --dark: #0C0C0C;
  --surface: #141414;
  --surface2: #1C1C1C;
  --surface3: #222222;
  --border: rgba(200,151,26,0.18);
  --border-strong: rgba(200,151,26,0.45);
  --text: #E8E4DA;
  --text-muted: #7A7870;
  --text-dim: #4A4840;
  --green: #4A9E4E;
  --green-light: #6DC870;
  --red: #9E4A4A;
  --red-light: #C87070;
  --blue: #3A7AC8;
  --blue-light: #70A8E8;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Syne', sans-serif;
  background: var(--dark);
  color: var(--text);
  min-height: 100vh;
  display: grid;
  grid-template-columns: 200px 1fr;
  grid-template-rows: auto 1fr;
}

/* TOP BAR */
.topbar {
  grid-column: 1 / -1;
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.75rem 1.5rem;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
}

.topbar-logo {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--gold-light);
  letter-spacing: -0.01em;
}

.topbar-sep {
  color: var(--border-strong);
  font-weight: 300;
}

.topbar-sub {
  font-family: 'DM Mono', monospace;
  font-size: 0.62rem;
  color: var(--gold-dim);
  letter-spacing: 0.1em;
}

.topbar-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 1rem;
}

.api-pill {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  background: rgba(74,158,78,0.1);
  border: 1px solid rgba(74,158,78,0.25);
  border-radius: 20px;
  padding: 0.25rem 0.75rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  color: var(--green-light);
  letter-spacing: 0.06em;
}

.dot { width: 6px; height: 6px; border-radius: 50%; }
.dot-green { background: var(--green); }
.dot-amber { background: var(--gold); }
.dot-red { background: var(--red); }

/* SIDEBAR */
.sidebar {
  border-right: 1px solid var(--border);
  padding: 1rem 0;
  background: var(--surface);
  overflow-y: auto;
}

.sidebar-section {
  padding: 0.4rem 1rem 0.2rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.58rem;
  color: var(--text-dim);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-top: 0.75rem;
}

.sidebar-section:first-child { margin-top: 0; }

.nav-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.45rem 1rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.12s;
  border-left: 2px solid transparent;
  letter-spacing: 0.02em;
}

.nav-item:hover {
  color: var(--text);
  background: rgba(200,151,26,0.05);
}

.nav-item.active {
  color: var(--gold-light);
  border-left-color: var(--gold);
  background: rgba(200,151,26,0.08);
}

.nav-icon {
  font-size: 12px;
  width: 14px;
  text-align: center;
}

/* MAIN CONTENT */
.main {
  overflow-y: auto;
  padding: 1.5rem;
  background: var(--dark);
}

.panel { display: none; }
.panel.active { display: block; }

.panel-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.25rem;
  letter-spacing: -0.01em;
}

.panel-sub {
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  color: var(--text-muted);
  margin-bottom: 1.25rem;
  letter-spacing: 0.02em;
}

/* CARDS */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.1rem 1.25rem;
  margin-bottom: 1rem;
}

.card-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  color: var(--gold-dim);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 0.9rem;
}

/* FORM ELEMENTS */
label {
  display: block;
  font-family: 'DM Mono', monospace;
  font-size: 0.65rem;
  color: var(--text-muted);
  letter-spacing: 0.04em;
  margin-bottom: 0.3rem;
  margin-top: 0.75rem;
}

label:first-of-type { margin-top: 0; }

input, textarea, select {
  width: 100%;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 5px;
  color: var(--text);
  font-family: 'DM Mono', monospace;
  font-size: 0.78rem;
  padding: 0.5rem 0.75rem;
  outline: none;
  transition: border-color 0.12s;
  -webkit-appearance: none;
}

input:focus, textarea:focus, select:focus { border-color: var(--gold); }
textarea { resize: vertical; min-height: 80px; line-height: 1.5; }
select option { background: var(--surface2); }

.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.75rem; }

/* BUTTONS */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.4rem;
  padding: 0.5rem 1.1rem;
  border-radius: 5px;
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.06em;
  cursor: pointer;
  border: none;
  transition: all 0.12s;
  white-space: nowrap;
}

.btn + .btn { margin-left: 0.5rem; }

.btn-gold {
  background: var(--gold);
  color: #000;
  font-weight: 500;
}
.btn-gold:hover { background: var(--gold-light); }
.btn-gold:disabled { opacity: 0.35; cursor: not-allowed; }

.btn-ghost {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-muted);
}
.btn-ghost:hover { border-color: var(--gold); color: var(--text); }

.btn-danger {
  background: transparent;
  border: 1px solid rgba(158,74,74,0.4);
  color: var(--red-light);
}
.btn-danger:hover { background: rgba(158,74,74,0.1); }

.btn-sm { padding: 0.3rem 0.7rem; font-size: 0.62rem; }

.btn-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.9rem; }

/* RESULT ITEMS */
.result-card {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 0.85rem 1rem;
  margin-bottom: 0.5rem;
}

.result-card:hover {
  border-color: var(--border-strong);
}

.result-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.75rem;
  margin-bottom: 0.4rem;
}

.result-name {
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--text);
}

.result-meta {
  font-family: 'DM Mono', monospace;
  font-size: 0.65rem;
  color: var(--text-muted);
  line-height: 1.7;
  margin-top: 0.3rem;
}

.result-id {
  font-family: 'DM Mono', monospace;
  font-size: 0.58rem;
  color: var(--text-dim);
}

/* BADGES */
.badge {
  display: inline-block;
  font-family: 'DM Mono', monospace;
  font-size: 0.58rem;
  padding: 2px 7px;
  border-radius: 3px;
  letter-spacing: 0.05em;
  white-space: nowrap;
}

.badge-open { background: rgba(74,158,78,0.12); color: var(--green-light); border: 1px solid rgba(74,158,78,0.25); }
.badge-partial { background: rgba(200,151,26,0.12); color: var(--gold-light); border: 1px solid var(--border); }
.badge-assigned { background: rgba(58,122,200,0.12); color: var(--blue-light); border: 1px solid rgba(58,122,200,0.25); }
.badge-closed, .badge-cancelled { background: rgba(158,74,74,0.12); color: var(--red-light); border: 1px solid rgba(158,74,74,0.25); }
.badge-pending { background: rgba(200,151,26,0.08); color: var(--gold-dim); border: 1px solid var(--border); }
.badge-confirmed { background: rgba(74,158,78,0.12); color: var(--green-light); border: 1px solid rgba(74,158,78,0.25); }

/* SKILL TAGS */
.skill-tag {
  display: inline-block;
  background: rgba(200,151,26,0.08);
  border: 1px solid var(--border);
  border-radius: 3px;
  font-family: 'DM Mono', monospace;
  font-size: 0.58rem;
  padding: 1px 6px;
  color: var(--gold-dim);
  margin: 2px 2px 0 0;
}

/* STATUS MESSAGES */
.msg { font-family: 'DM Mono', monospace; font-size: 0.7rem; padding: 0.5rem 0; line-height: 1.5; }
.msg-loading { color: var(--text-muted); }
.msg-error { color: var(--red-light); }
.msg-success { color: var(--green-light); }
.msg-empty { color: var(--text-dim); font-style: italic; }

/* OUTPUT BOX */
.output-box {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-left: 2px solid var(--gold-dim);
  border-radius: 0 5px 5px 0;
  padding: 0.85rem 1rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: var(--text);
  margin-top: 0.75rem;
  line-height: 1.75;
  white-space: pre-wrap;
  word-break: break-word;
}

/* AI INDICATOR */
.ai-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  color: var(--gold-dim);
  letter-spacing: 0.08em;
  margin-bottom: 0.6rem;
}

.pulse {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--gold);
  animation: pulse 1.4s infinite;
}

@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.25;} }

/* SEPARATOR */
.sep { border: none; border-top: 1px solid var(--border); margin: 1rem 0; }

/* INFO BOX */
.info-box {
  background: rgba(200,151,26,0.04);
  border: 1px solid var(--border);
  border-left: 2px solid var(--gold);
  border-radius: 0 5px 5px 0;
  padding: 0.7rem 0.9rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  color: var(--text-muted);
  line-height: 1.7;
  margin-top: 0.75rem;
}

/* STATS ROW */
.stats-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 0.85rem 1rem;
}

.stat-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.58rem;
  color: var(--text-dim);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 0.4rem;
}

.stat-value {
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--gold-light);
  letter-spacing: -0.02em;
}

/* CONVERSATION */
.msg-bubble {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 0.7rem 0.85rem;
  margin-bottom: 0.5rem;
}

.msg-sender {
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  color: var(--gold-dim);
  letter-spacing: 0.06em;
  margin-bottom: 0.3rem;
}

.msg-body {
  font-size: 0.82rem;
  color: var(--text);
  line-height: 1.55;
}

.msg-time {
  font-family: 'DM Mono', monospace;
  font-size: 0.55rem;
  color: var(--text-dim);
  margin-top: 0.3rem;
}

/* ACCOUNT STATUS */
.capability-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.4rem 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.8rem;
}
.capability-row:last-child { border-bottom: none; }
.cap-label { flex: 1; font-family: 'DM Mono', monospace; font-size: 0.7rem; color: var(--text-muted); }
.cap-yes { color: var(--green-light); font-family: 'DM Mono', monospace; font-size: 0.65rem; }
.cap-no  { color: var(--red-light);   font-family: 'DM Mono', monospace; font-size: 0.65rem; }

@media (max-width: 700px) {
  body { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  .main { padding: 1rem; }
  .grid-2, .grid-3 { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <span class="topbar-logo">HumanAIOS</span>
  <span class="topbar-sep">×</span>
  <span class="topbar-logo" style="color:var(--text);">RentAHuman</span>
  <span class="topbar-sub">UNIT ZERO CONSOLE v2</span>
  <div class="topbar-right">
    <div class="api-pill">
      <div class="dot dot-green"></div>
      API LIVE
    </div>
  </div>
</div>

<!-- SIDEBAR -->
<nav class="sidebar">
  <div class="sidebar-section">Discovery</div>
  <div class="nav-item active" onclick="show('search-humans')">
    <span class="nav-icon">⊙</span> Search Humans
  </div>
  <div class="nav-item" onclick="show('browse-services')">
    <span class="nav-icon">◈</span> Browse Services
  </div>
  <div class="nav-item" onclick="show('browse-bounties')">
    <span class="nav-icon">◉</span> Open Bounties
  </div>

  <div class="sidebar-section">Hire</div>
  <div class="nav-item" onclick="show('post-bounty')">
    <span class="nav-icon">+</span> Post Bounty
  </div>
  <div class="nav-item" onclick="show('ai-compose')">
    <span class="nav-icon">✦</span> AI Compose
  </div>
  <div class="nav-item" onclick="show('rent-human')">
    <span class="nav-icon">→</span> Rent Direct
  </div>

  <div class="sidebar-section">Manage</div>
  <div class="nav-item" onclick="show('my-bounties')">
    <span class="nav-icon">◫</span> My Bounties
  </div>
  <div class="nav-item" onclick="show('my-rentals')">
    <span class="nav-icon">◧</span> My Rentals
  </div>
  <div class="nav-item" onclick="show('my-bookings')">
    <span class="nav-icon">◪</span> My Bookings
  </div>

  <div class="sidebar-section">Conversations</div>
  <div class="nav-item" onclick="show('conversations')">
    <span class="nav-icon">◌</span> All Chats
  </div>
  <div class="nav-item" onclick="show('start-convo')">
    <span class="nav-icon">◎</span> New Message
  </div>

  <div class="sidebar-section">Account</div>
  <div class="nav-item" onclick="show('account-status')">
    <span class="nav-icon">◑</span> Account Status
  </div>
  <div class="nav-item" onclick="show('api-keys')">
    <span class="nav-icon">◐</span> API Keys
  </div>
</nav>

<!-- MAIN -->
<main class="main">

<!-- ═══ SEARCH HUMANS ═══ -->
<div id="panel-search-humans" class="panel active">
  <div class="panel-title">Search Humans</div>
  <div class="panel-sub">Find available workers by skill, name, or rate</div>
  <div class="card">
    <div class="grid-2">
      <div><label>Skill</label><input id="sh-skill" placeholder="Research, Errands, Meetings…" /></div>
      <div><label>Name</label><input id="sh-name" placeholder="Search by name" /></div>
    </div>
    <div class="grid-3" style="margin-top:0.75rem;">
      <div><label>Min Rate ($/hr)</label><input type="number" id="sh-minrate" placeholder="0" /></div>
      <div><label>Max Rate ($/hr)</label><input type="number" id="sh-maxrate" placeholder="200" /></div>
      <div><label>Results</label>
        <select id="sh-limit">
          <option value="10">10</option>
          <option value="25" selected>25</option>
          <option value="50">50</option>
          <option value="100">100</option>
        </select>
      </div>
    </div>
    <div class="btn-row"><button class="btn btn-gold" onclick="searchHumans()">SEARCH</button></div>
  </div>
  <div id="sh-results"></div>
</div>

<!-- ═══ BROWSE SERVICES ═══ -->
<div id="panel-browse-services" class="panel">
  <div class="panel-title">Browse Services</div>
  <div class="panel-sub">Bookable services available on the platform</div>
  <div class="card">
    <div class="grid-2">
      <div><label>Search</label><input id="bs-search" placeholder="e.g. tutoring, delivery…" /></div>
      <div><label>Sort By</label>
        <select id="bs-sort">
          <option value="relevance">Relevance</option>
          <option value="price_asc">Price (low→high)</option>
          <option value="price_desc">Price (high→low)</option>
          <option value="rating">Rating</option>
        </select>
      </div>
    </div>
    <div class="btn-row"><button class="btn btn-gold" onclick="browseServices()">BROWSE</button></div>
  </div>
  <div id="bs-results"></div>
</div>

<!-- ═══ BROWSE BOUNTIES ═══ -->
<div id="panel-browse-bounties" class="panel">
  <div class="panel-title">Open Bounties</div>
  <div class="panel-sub">See what tasks are currently live on the platform</div>
  <div class="card">
    <div class="grid-2">
      <div><label>Status Filter</label>
        <select id="bb-status">
          <option value="">All active</option>
          <option value="open">Open only</option>
          <option value="partially_filled">Partially filled</option>
        </select>
      </div>
      <div><label>Limit</label>
        <select id="bb-limit">
          <option value="20" selected>20</option>
          <option value="50">50</option>
        </select>
      </div>
    </div>
    <div class="btn-row"><button class="btn btn-gold" onclick="browseBounties()">LOAD BOUNTIES</button></div>
  </div>
  <div id="bb-results"></div>
</div>

<!-- ═══ POST BOUNTY ═══ -->
<div id="panel-post-bounty" class="panel">
  <div class="panel-title">Post a Bounty</div>
  <div class="panel-sub">Create a task posting for humans to apply to</div>
  <div class="card">
    <label>Task Title</label>
    <input id="pb-title" placeholder="e.g. ACAT Research Participant — AI Behavioral Assessment" />
    <label>Description</label>
    <textarea id="pb-desc" rows="6" placeholder="Describe the task clearly — what's needed, how long it takes, any requirements…"></textarea>
    <div class="grid-3" style="margin-top:0.75rem;">
      <div><label>Price Type</label>
        <select id="pb-pricetype">
          <option value="fixed">Fixed</option>
          <option value="hourly">Hourly</option>
        </select>
      </div>
      <div><label>Price ($)</label><input type="number" id="pb-price" value="5" /></div>
      <div><label>Est. Hours</label><input type="number" id="pb-hours" value="0.5" step="0.5" /></div>
    </div>
    <div class="grid-2" style="margin-top:0.75rem;">
      <div><label>Spots Available</label><input type="number" id="pb-spots" value="25" min="1" max="500" /></div>
      <div><label>Agent Type</label><input id="pb-agent" value="humanaios" /></div>
    </div>
    <div class="btn-row"><button class="btn btn-gold" onclick="postBounty()">POST BOUNTY</button></div>
    <div id="pb-result"></div>
  </div>
</div>

<!-- ═══ AI COMPOSE ═══ -->
<div id="panel-ai-compose" class="panel">
  <div class="panel-title">AI Bounty Composer</div>
  <div class="panel-sub">Claude Sonnet writes your bounty copy from a plain-language brief</div>
  <div class="card">
    <div class="ai-tag"><div class="pulse"></div> POWERED BY CLAUDE SONNET</div>
    <label>What do you need humans to do?</label>
    <textarea id="ac-brief" rows="3" placeholder="e.g. Complete a 30-minute AI self-assessment study for our research platform. We'll pay $5. Fully remote, online form."></textarea>
    <div class="grid-2" style="margin-top:0.75rem;">
      <div><label>Tone</label>
        <select id="ac-tone">
          <option value="professional and mission-driven, emphasizing AI ethics research">Mission-Driven Research</option>
          <option value="friendly and accessible">Friendly & Accessible</option>
          <option value="academic and precise">Academic & Precise</option>
          <option value="urgent and direct">Urgent & Direct</option>
          <option value="community-oriented and warm, mentioning Cherokee Nation and recovery mission">Community & Purpose</option>
        </select>
      </div>
      <div><label>Suggested Price ($)</label><input type="number" id="ac-price" value="5" /></div>
    </div>
    <div class="btn-row"><button class="btn btn-gold" onclick="composeBounty()">GENERATE COPY</button></div>
    <div id="ac-output"></div>
  </div>
</div>

<!-- ═══ RENT DIRECT ═══ -->
<div id="panel-rent-human" class="panel">
  <div class="panel-title">Rent a Human Directly</div>
  <div class="panel-sub">One-step hire — creates bounty, assigns human, returns Stripe checkout</div>
  <div class="card">
    <div class="info-box">Funds are held in escrow until you release payment after task completion.</div>
    <label style="margin-top:1rem;">Human ID</label>
    <input id="rh-humanid" placeholder="human_abc123 — get this from Search Humans" />
    <label>Task Title</label>
    <input id="rh-title" placeholder="Brief task description" />
    <label>Task Description</label>
    <textarea id="rh-desc" rows="3" placeholder="Full details of what you need done…"></textarea>
    <div class="grid-3" style="margin-top:0.75rem;">
      <div><label>Price ($)</label><input type="number" id="rh-price" value="25" /></div>
      <div><label>Price Type</label>
        <select id="rh-pricetype"><option value="fixed">Fixed</option><option value="hourly">Hourly</option></select>
      </div>
      <div><label>Est. Hours</label><input type="number" id="rh-hours" value="1" step="0.5" /></div>
    </div>
    <div class="btn-row"><button class="btn btn-gold" onclick="rentHuman()">RENT + GET CHECKOUT LINK</button></div>
