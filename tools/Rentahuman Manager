  } catch(e) { alert('Error: '+e.message); }
}

async function cancelBounty() {
  const id = document.getElementById('mb-id').value.trim();
  if (!id) { err('mb-result','Enter bounty ID'); return; }
  if (!confirm('Cancel this bounty?')) return;
  try {
    const d = await patch('/bounties/'+id, { status:'cancelled' });
    document.getElementById('mb-result').innerHTML = d.success
      ? '<div class="msg msg-success" style="margin-top:0.75rem;">Bounty cancelled.</div>'
      : `<div class="msg msg-error" style="margin-top:0.75rem;">${escHtml(d.error||'Failed')}</div>`;
  } catch(e) { err('mb-result', e.message); }
}

// ── MY RENTALS ──
async function getRentals() {
  loading('mr-results');
  try {
    const d = await get('/rentals');
    if (d.success) {
      const r = d.rentals||d.data||[];
      if (!r.length) { empty('mr-results'); return; }
      document.getElementById('mr-results').innerHTML =
        `<div class="msg msg-loading" style="margin:0.5rem 0;">${r.length} rental(s)</div>` +
        r.map(x => `
          <div class="result-card">
            <div class="result-header">
              <div>
                <div class="result-name">${escHtml(x.title||x.id)}</div>
                <div class="result-meta">${escHtml(x.humanName||'')} · $${x.price}</div>
                ${x.nextSteps ? `<div class="info-box" style="margin-top:0.5rem;">${escHtml(x.nextSteps)}</div>` : ''}
              </div>
              <div style="text-align:right;flex-shrink:0;">
                ${statusBadge(x.status)}
                <div class="result-id" style="margin-top:4px;">${x.id}</div>
              </div>
            </div>
          </div>`).join('');
    } else { err('mr-results', d.error||'Failed'); }
  } catch(e) { err('mr-results', e.message); }
}

async function releaseRental() {
  const id = document.getElementById('mr-release-id').value.trim();
  if (!id) { err('mr-release-result','Enter rental ID'); return; }
