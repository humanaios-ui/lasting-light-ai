<script>
const API_KEY = 'rah_f303bc7806746db3d793f04bd125aa4c';
const BASE = 'https://rentahuman.ai/api';

// ── NAVIGATION ──
function show(name) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  event.currentTarget.classList.add('active');
}

// ── API HELPERS ──
async function get(path) {
  const r = await fetch(BASE + path, { headers: { 'X-API-Key': API_KEY } });
  return r.json();
}

async function post(path, body) {
  const r = await fetch(BASE + path, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-API-Key': API_KEY },
    body: JSON.stringify(body)
  });
  return r.json();
}

async function patch(path, body) {
  const r = await fetch(BASE + path, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-API-Key': API_KEY },
    body: JSON.stringify(body)
  });
  return r.json();
}

function loading(el) { document.getElementById(el).innerHTML = '<div class="msg msg-loading">Loading…</div>'; }
function err(el, msg) { document.getElementById(el).innerHTML = `<div class="msg msg-error">Error: ${escHtml(msg)}</div>`; }
function success(el, msg) { document.getElementById(el).innerHTML = `<div class="msg msg-success">${escHtml(msg)}</div>`; }
function empty(el) { document.getElementById(el).innerHTML = '<div class="msg msg-empty">No results found.</div>'; }

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function statusBadge(s) {
  s = (s||'unknown').toLowerCase();
  const cls = s === 'open' ? 'badge-open' : s === 'partially_filled' ? 'badge-partial' : s === 'assigned' ? 'badge-assigned' : s === 'confirmed' ? 'badge-confirmed' : s === 'pending' ? 'badge-pending' : 'badge-closed';
  return `<span class="badge ${cls}">${s}</span>`;
}

function fmtDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
}

// ── SEARCH HUMANS ──
async function searchHumans() {
  loading('sh-results');
  try {
    let qs = `?limit=${document.getElementById('sh-limit').value}`;
    const skill = document.getElementById('sh-skill').value.trim();
    const name  = document.getElementById('sh-name').value.trim();
    const minR  = document.getElementById('sh-minrate').value;
    const maxR  = document.getElementById('sh-maxrate').value;
    if (skill) qs += `&skill=${encodeURIComponent(skill)}`;
    if (name)  qs += `&name=${encodeURIComponent(name)}`;
    if (minR)  qs += `&minRate=${minR}`;
    if (maxR)  qs += `&maxRate=${maxR}`;

    const d = await get('/humans' + qs);
    if (!d.success) { err('sh-results', d.error||'Request failed'); return; }
    const h = d.humans || [];
    if (!h.length) { empty('sh-results'); return; }

    document.getElementById('sh-results').innerHTML =
      `<div class="msg msg-loading" style="margin-bottom:0.5rem;">${h.length} result${h.length!==1?'s':''}</div>` +
      h.map(p => `
        <div class="result-card">
          <div class="result-header">
            <div>
              <div class="result-name">${escHtml(p.name||'—')}</div>
              <div class="result-meta">${escHtml(p.location||'')}</div>
              ${(p.skills||[]).map(s=>`<span class="skill-tag">${escHtml(s)}</span>`).join('')}
              ${p.bio ? `<div class="result-meta" style="margin-top:0.35rem;color:var(--text);">${escHtml(p.bio.substring(0,140))}${p.bio.length>140?'…':''}</div>` : ''}
            </div>
            <div style="text-align:right;flex-shrink:0;">
              <div style="font-family:'DM Mono',monospace;font-size:0.85rem;color:var(--gold-light);">$${p.hourlyRate||'?'}/hr</div>
              <div class="result-id" style="margin-top:4px;">${p.id}</div>
              <button class="btn btn-ghost btn-sm" style="margin-top:6px;" onclick="fillHumanId('${p.id}')">USE ID</button>
            </div>
          </div>
        </div>`).join('');
  } catch(e) { err('sh-results', e.message); }
}

function fillHumanId(id) {
  ['rh-humanid','sc-humanid'].forEach(f => { const el=document.getElementById(f); if(el) el.value=id; });
}

