              <div>
                <div class="result-name">${escHtml(x.title||x.service||x.id)}</div>
                <div class="result-meta">${escHtml(x.humanName||'')} · ${fmtDate(x.startTime)} · $${x.price||'?'}</div>
              </div>
              ${statusBadge(x.status)}
