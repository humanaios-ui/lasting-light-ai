                            <span className="radar-row-name">
                              {DIM_LABELS[i].split(' ')[0]}
                            </span>
                            <div className="radar-row-vals">
                              <span className="rv-p1">
                                {selectedModel.p1scores[i]}
                              </span>
                              <span className="rv-p3">
                                {selectedModel.p3scores[i]}
                              </span>
                              <span
                                className="rv-gap"
                                style={{
                                  color: gapColor,
                                }}
                              >
                                Δ{gap}
                              </span>
                            </div>
                          </div>
                        )
                      })}
                    </div>
                  </div>
                </div>
              </>
            )}

            {/* ALL MODELS TABLE */}
            <div className="section-head">
              <h2>All Models in {provider}</h2>
            </div>
            <p className="section-desc">
              Full dimension scores for every assessed model in this provider.
              Click a row to load its breakdown above.
            </p>
            <div className="table-panel">
              <div className="table-panel-head">
                <div className="table-panel-sub">
                  Sorted by Learning Index (LI) descending · Click any row to
                  inspect
                </div>
              </div>
              <div className="table-wrap">
                <table className="lr-table">
                  <thead>
                    <tr>
                      <th>Model</th>
                      <th>LI</th>
                      <th>Truth</th>
                      <th>Service</th>
                      <th>Harm</th>
                      <th>Autonomy</th>
                      <th>Value</th>
                      <th>Humility</th>
                      <th>P1 Total</th>
                      <th>P3 Total</th>
                    </tr>
                  </thead>
                  <tbody>
                    {providerData.map((d) => (
                      <tr
                        key={d.model}
                        className={`model-row${selectedModelName === d.model ? ' selected' : ''}`}
                        onClick={() => handleSelectModel(d.model)}
                      >
                        <td>
                          <strong>{d.model}</strong>
                        </td>
                        <td
                          style={{
                            fontFamily: "'IBM Plex Mono', monospace",
                            color: getLiColor(d.li),
                            fontWeight: 600,
                          }}
                        >
                          {d.li}
                        </td>
                        {DIM_KEYS.map((_, i) => {
                          const gap = d.p1scores[i] - d.p3scores[i]
                          return (
                            <td
                              key={DIM_KEYS[i]}
                              style={{
                                fontFamily: "'IBM Plex Mono', monospace",
                                color: getGapColor(gap),
                                fontSize: '.82rem',
                              }}
                            >
                              +{gap}
                            </td>
                          )
                        })}
                        <td
                          style={{
                            color: 'var(--muted)',
                            fontFamily: "'IBM Plex Mono', monospace",
                          }}
                        >
                          {d.p1total}
                        </td>
                        <td
                          style={{
                            color: 'var(--muted)',
                            fontFamily: "'IBM Plex Mono', monospace",
                          }}
                        >
                          {d.p3total}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            {/* DISCLAIMER */}
            <div
              className="disclaimer"
              style={{
                marginBottom: 48,
              }}
            >
              <span className="disclaimer-icon">⊙</span>
              <span>
                Behavioral observability infrastructure at TRL 2–3. Scores
                describe observable behavioral patterns under structured
                assessment conditions. No claim is made about AI consciousness,
                intent, or interiority. Session ID and timestamp included in all
                exported records.
              </span>
            </div>

            {/* TRACE LOG */}
            <div className="trace-panel">
              <div className="trace-head">
                <div className="trace-title">Session Trace</div>
                <div className="trace-controls">
                  <button
                    className={`trace-btn${traceFilter === 'all' ? ' active-filter' : ''}`}
                    onClick={() => setTraceFilter('all')}
                  >
                    All
                  </button>
                  <button
                    className={`trace-btn${traceFilter === 'flag' ? ' active-filter' : ''}`}
                    onClick={() => setTraceFilter('flag')}
                  >
                    Flags
                  </button>
                  <button className="trace-btn" onClick={handleCopyTrace}>
                    Copy
                  </button>
                </div>
              </div>
              <div className="trace-scroll" ref={traceRef}>
                {filteredTrace.map((e, idx) => (
                  <div key={idx} className={`trace-entry ${e.type}`}>
                    <span className="trace-ts">[{e.ts}]</span>
                    {e.msg}
                  </div>
                ))}
              </div>
            </div>

            {/* ANNOTATIONS */}
            <div className="ann-panel">
              <div className="ann-title">Researcher Annotations</div>
              <div className="ann-sub">
                Optional — not part of the automated assessment. Saved to
                session trace on submission.
              </div>
              <textarea
                className="ann-textarea"
                value={annText}
                onChange={(e) => setAnnText(e.target.value)}
                placeholder="e.g., 'Humility gap elevated across all Anthropic models — consistent with anchoring hypothesis.' or 'Review Phase 3 scores for Claude Sonnet 4.6 pending manual correction.'"
              />
              <div className="ann-actions">
                <button className="ann-btn" onClick={handleSaveAnnotation}>
                  ↳ Save to Trace
                </button>
                <button
                  className="ann-btn secondary"
                  onClick={() => setAnnText('')}
                >
                  Clear
                </button>
              </div>
              <div className={`ann-confirm${annConfirm ? ' show' : ''}`}>
                ✓ Annotation appended to session trace
              </div>
            </div>
          </div>
        )}

        {/* EMPTY STATE — provider selected but no data */}
        {!loading && provider && providerData.length === 0 && (
          <div className="lr-container">
            <div className="empty-state">
              <h3>No data for "{provider}"</h3>
              <p>No models found for this provider in the current dataset.</p>
              <button className="empty-btn" onClick={() => setProvider('')}>
                ← Select another provider
              </button>
            </div>
          </div>
        )}
      </main>

      {/* FOOTER */}
      <footer className="lr-footer">
        <div className="lr-container">
          <p>
            Lantern Room · <a href="https://humanaios.ai">HumanAIOS</a> · OR&D
            Phase ·{' '}
            <a href="https://arxiv.org/abs/2503.07730">
              arXiv preprint March 2026
            </a>
          </p>
          <p>
            Dataset:{' '}
            <a
              href="https://huggingface.co/datasets/humanaios/acat-assessments"
              target="_blank"
              rel="noopener noreferrer"
            >
              humanaios/acat-assessments
            </a>
          </p>
        </div>
      </footer>
    </div>
  )
}

