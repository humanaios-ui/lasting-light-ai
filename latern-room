```components/RadarChart.tsx
import React, { useMemo } from 'react'
import {
  Radar,
  RadarChart as RechartsRadarChart,
  PolarGrid,
  PolarAngleAxis,
  PolarRadiusAxis,
  ResponsiveContainer,
  Legend,
  Tooltip,
} from 'recharts'
import { DIM_LABELS } from '../lib/data'
import type { ModelData } from '../lib/data'
interface RadarChartProps {
  model: ModelData
}
export function RadarChart({ model }: RadarChartProps) {
  const chartData = useMemo(
    () =>
      DIM_LABELS.map((label, i) => ({
        dimension: label,
        'Phase 1': model.p1scores[i],
        'Phase 3': model.p3scores[i],
      })),
    [model],
  )
  return (
    <ResponsiveContainer width="100%" height={300}>
      <RechartsRadarChart data={chartData} cx="50%" cy="50%" outerRadius="75%">
        <PolarGrid stroke="rgba(255,255,255,0.08)" />
        <PolarAngleAxis
          dataKey="dimension"
          tick={{
            fill: '#f4ebdf',
            fontSize: 10,
          }}
        />
        <PolarRadiusAxis
          domain={[50, 95]}
          tick={{
            fill: '#b9ad99',
            fontSize: 9,
          }}
          axisLine={false}
        />
        <Radar
          name="Phase 1"
          dataKey="Phase 1"
          stroke="#d4a04a"
          fill="rgba(212,160,74,0.15)"
          strokeWidth={2}
          dot={{
            r: 3,
            fill: '#d4a04a',
          }}
        />
        <Radar
          name="Phase 3"
          dataKey="Phase 3"
          stroke="#88a7d8"
          fill="rgba(136,167,216,0.07)"
          strokeWidth={2}
          dot={{
            r: 3,
            fill: '#88a7d8',
          }}
        />
        <Legend
          wrapperStyle={{
            color: '#f4ebdf',
            fontSize: 11,
          }}
        />
        <Tooltip
          contentStyle={{
            backgroundColor: 'rgba(15,13,11,0.96)',
            border: '1px solid rgba(212,160,74,0.35)',
            borderRadius: 8,
            color: '#c2b8a6',
          }}
          labelStyle={{
            color: '#f4ebdf',
          }}
        />
      </RechartsRadarChart>
    </ResponsiveContainer>
  )
}

