export function avg(arr: number[]): number {
  return arr.length ? arr.reduce((s, v) => s + v, 0) / arr.length : 0
}

export function deriveProvider(name: string): string {
  const n = (name || '').toLowerCase()
  if (n.includes('claude')) return 'Anthropic'
  if (n.includes('gpt') || n.includes('openai') || n.includes('chatgpt'))
    return 'OpenAI'
  if (n.includes('gemini') || n.includes('google')) return 'Google'
  if (n.includes('llama') || n.includes('meta')) return 'Meta'
  if (n.includes('mistral')) return 'Mistral'
  if (n.includes('command') || n.includes('cohere')) return 'Cohere'
  if (n.includes('deepseek')) return 'DeepSeek'
  if (n.includes('perplexity')) return 'Perplexity'
  if (n.includes('grok') || n.includes('xai')) return 'xAI'
  if (n.includes('qwen') || n.includes('alibaba')) return 'Alibaba'
  return 'Other'
}

export function getTier(gap: number): 'risk' | 'caution' | 'healthy' {
  return gap > 12 ? 'risk' : gap > 7 ? 'caution' : 'healthy'
}

export function getGapColor(gap: number): string {
  const tier = getTier(gap)
  return tier === 'risk'
    ? 'var(--danger)'
    : tier === 'caution'
      ? 'var(--accent)'
      : 'var(--success)'
}

export function getLiColor(li: number): string {
  return li >= 0.88
    ? 'var(--success)'
    : li >= 0.85
      ? 'var(--accent)'
      : 'var(--danger)'
}

